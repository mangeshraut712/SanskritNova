{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/health.py": {
      "runtime": "@vercel/python@3.11",
      "maxDuration": 30
    },
    "api/info.py": {
      "runtime": "@vercel/python@3.11",
      "maxDuration": 30
    },
    "api/tracks.py": {
      "runtime": "@vercel/python@3.11",
      "maxDuration": 30
    },
    "api/transliterate.py": {
      "runtime": "@vercel/python@3.11",
      "maxDuration": 30
    },
    "api/chat.py": {
      "runtime": "@vercel/python@3.11",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health.py"
    },
    {
      "source": "/api/info",
      "destination": "/api/info.py"
    },
    {
      "source": "/api/tracks",
      "destination": "/api/tracks.py"
    },
    {
      "source": "/api/transliterate",
      "destination": "/api/transliterate.py"
    },
    {
      "source": "/api/chat",
      "destination": "/api/chat.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}
