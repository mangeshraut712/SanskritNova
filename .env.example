OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_NAME=SanskritNova AI
OPENROUTER_APP_URL=http://localhost:3000

# Original local RAG settings
SANSKRIT_RAG_DATA_DIR=data
SANSKRIT_RAG_INDEX_PATH=code/faiss_index.bin
SANSKRIT_RAG_CHUNKS_PATH=code/chunks.json
SANSKRIT_RAG_LEGACY_CHUNKS_PATH=code/chunks.npy
SANSKRIT_RAG_TFIDF_VECTORIZER_PATH=code/tfidf_vectorizer.joblib
SANSKRIT_RAG_EMBEDDING_BACKEND=tfidf
SANSKRIT_RAG_EMBEDDING_MODEL=distiluse-base-multilingual-cased-v1
SANSKRIT_RAG_MODEL_PATH=models/phi3.gguf
SANSKRIT_RAG_CHUNK_SIZE=300
SANSKRIT_RAG_CHUNK_OVERLAP=50
SANSKRIT_RAG_TOP_K=3
SANSKRIT_RAG_LLM_CTX=2048
SANSKRIT_RAG_LLM_THREADS=8
SANSKRIT_RAG_LLM_BATCH=256
SANSKRIT_RAG_MAX_TOKENS=300
SANSKRIT_RAG_TEMPERATURE=0.2
