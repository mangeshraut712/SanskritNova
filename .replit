language = "python3"
run = "uvicorn api.index:app --host 0.0.0.0 --port 8001 --reload"
modules = ["python-3.13:v18-20240101-3d4a20e"]

[packager]
language = "python3"
ignoredPackages = ["tests", "docs", "report", "data", ".github"]

[packager.features]
enabledForHosting = false
packageSearch = true
guessImports = true

[interpreter]
command = "python3.13"

[nix]
channel = "stable-23_11"

[deployment]
run = ["pip install -r requirements.txt", "uvicorn api.index:app --host 0.0.0.0 --port 8001"]
healthcheckPath = "/api/health"
healthcheckTimeout = 300